<Window x:Class="Metanit_Parser.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Metanit_Parser.Views"
        mc:Ignorable="d"
        Title="Knoledge Parser" Height="900" Width="1600">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
        <Menu Grid.Row="0">
            <MenuItem Header="Настройки"/>
        </Menu>

        <Grid Grid.Row="1">

            <TabControl Grid.Column="1" TabStripPlacement="Left">
                <TabItem>
                    <TabItem.Header>
                        <Image Source="pack://application:,,,/Resources/Images/icons8-search-more-100.png" Height="40"></Image>
                    </TabItem.Header>
                    <Grid>
                        <Grid.Background>
                            <RadialGradientBrush RadiusX="1" RadiusY="1">
                                <GradientStop Color="#FFD5E6EC" Offset="1"/>
                                <GradientStop Color="White"/>
                            </RadialGradientBrush>
                        </Grid.Background>
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Label HorizontalAlignment="Center" FontSize="36" FontFamily="Times New Roman" Margin="0,0,0,15">Что исследуем сегодня?</Label>
                            <StackPanel Orientation="Horizontal">
                                <TextBox Width="500" Padding="5,5,5,5">
                                </TextBox>
                                <Button Margin="10,0,0,0" Padding="10,1,10,1">Найти</Button>
                            </StackPanel>
                            <CheckBox Margin="10" Content="Сканировать весь домен" HorizontalAlignment="Center"></CheckBox>
                        </StackPanel>
                        
                    </Grid>
                </TabItem>
                <TabItem>
                    <TabItem.Header>
                        <Image Source="/Resources/Images/icons8-oil-pump-100.png" Height="40"></Image>
                    </TabItem.Header>
                    <Grid Background="#FFE5E5E5"/>
                </TabItem>
                <TabItem>
                    <TabItem.Header>
                        <Image Source="/Resources/Images/icons8-filter-100.png" Height="40"></Image>
                    </TabItem.Header>
                    <Grid Background="#FFE5E5E5"/>
                </TabItem>
                <TabItem>
                    <TabItem.Header>
                        <Image Source="/Resources/Images/icons8-acid-flask-100.png" Height="40"></Image>
                    </TabItem.Header>
                    <Grid Background="#FFE5E5E5"/>
                </TabItem>
                <TabItem>
                    <TabItem.Header>
                        <Image Source="/Resources/Images/icons8-eye-100.png" Height="40"></Image>
                    </TabItem.Header>
                    <Grid Background="#FFE5E5E5"/>
                </TabItem>
            </TabControl>

        </Grid>

        <StatusBar Grid.Row="2" Height="30"/>
    </Grid>
</Window>
