<Window x:Class="KnowParser.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KnowParser.Views"
        mc:Ignorable="d"
        Title="Knoledge Parser" Height="900" Width="1600">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="5"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>
        <Menu Grid.Row="0">
            <MenuItem Header="Настройки" Command="{Binding OpenSettingCommand}"/>
        </Menu>

        <Grid Grid.Row="1">
            <Grid.Background>
                <RadialGradientBrush RadiusX="1" RadiusY="1">
                    <GradientStop Color="#FFD5E6EC" Offset="1"/>
                    <GradientStop Color="White"/>
                </RadialGradientBrush>
            </Grid.Background>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Label HorizontalAlignment="Center" FontSize="36" FontFamily="Times New Roman" Margin="0,0,0,15">Что исследуем сегодня?</Label>
                <StackPanel Orientation="Horizontal">
                    <TextBox Width="500" Padding="5,5,5,5" Text="{Binding URL}" VerticalContentAlignment="Center"/>

                    <Button Margin="10,0,0,0" Padding="10,1,10,1" Command="{Binding BeginSearchCommand}">
                        <Image Source="pack://application:,,,/Resources/Images/icons8-search-more-100.png" Height="40"></Image>
                    </Button>
                </StackPanel>
                <CheckBox Margin="10" Content="Сканировать весь домен" HorizontalAlignment="Center" IsChecked="{Binding ScanningFullSite}"/>
            </StackPanel>
        </Grid>

        <GridSplitter Grid.Row="2" Background="LightGray" HorizontalAlignment="Stretch" Cursor="SizeNS"/>
        
        <!-- Status Bar -->
        <StatusBar Grid.Row="3">
            <StatusBarItem HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                <TextBox Grid.Row="2" Text="{Binding Log}" VerticalScrollBarVisibility="Auto"/>
            </StatusBarItem>
        </StatusBar>
        
    </Grid>
</Window>
